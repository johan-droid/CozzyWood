# Cozzywood Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# 
# 🆓 ZERO-COST STACK - All services have generous free tiers
# ============================================

# ============================================
# API KEYS & SECRETS
# ============================================

# YouTube Integration (NO API KEY NEEDED!)
# Using InnerTube/surfyt-api for quota-free access
# https://github.com/zerodytrash/YouTube-Internal-Clients
YOUTUBE_API_ENABLED=true
# Leave YOUTUBE_API_KEY empty - not using official API

# Spotify Developer Dashboard (Search & Preview Only)
# https://developer.spotify.com/dashboard
# Free tier: 180 requests/minute - sufficient for personal use
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Pexels API (Images & Backgrounds)
# https://www.pexels.com/api/
# Free tier: 200 requests/hour (better than Unsplash's 50/hr)
PEXELS_API_KEY=your_pexels_api_key_here

# Giphy API (optional, for GIFs in chat)
# https://developers.giphy.com/dashboard
# Free tier available
GIPHY_API_KEY=your_giphy_api_key_here

# ============================================
# DATABASE & AUTH - SUPABASE (FREE TIER)
# ============================================
# Supabase provides: PostgreSQL DB (500MB) + Auth + API
# https://supabase.com/
# No separate database hosting needed!

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# CACHE & SYNC STATE - UPSTASH REDIS (FREE)
# ============================================
# Upstash Redis: 500,000 commands/month (FREE)
# https://upstash.com/redis
# Serverless, no server management needed

UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# Legacy REDIS_URL format (for compatibility)
REDIS_URL=redis://default:your_upstash_token@your-redis.upstash.io:6379

# ============================================
# FILE STORAGE - CLOUDFLARE R2 (FREE)
# ============================================
# Cloudflare R2: 10GB storage + 10M read ops/month (FREE)
# https://www.cloudflare.com/developer-platform/r2/
# S3-compatible, no egress fees!

R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=cozzywood-media
R2_PUBLIC_URL=https://your-r2-public-domain.com

# ============================================
# VIDEO CALL - WEBRTC TURN SERVER (FREE)
# ============================================
# Metered.ca Open Relay Project: 20GB/month (FREE)
# https://www.metered.ca/products/open-relay/
# No credit card required, highly reliable

TURN_SERVER_URL=turn:openrelay.metered.ca:443
TURN_SERVER_USERNAME=cozzywood_user
TURN_SERVER_PASSWORD=your_turn_password_here
# Get credentials from: https://www.metered.ca/products/open-relay/

# Alternative: Self-hosted coturn on Railway (if needed)
# COTURN_SERVER_URL=turn:your-railway-app.railway.app:3478
# COTURN_USERNAME=your_username
# COTURN_PASSWORD=your_password

# ============================================
# AUTHENTICATION
# ============================================

# JWT Secret (generate a strong random string)
# You can generate one with: openssl rand -base64 32
# Or use: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your_super_secure_jwt_secret_here_change_this_in_production

# ============================================
# APP CONFIGURATION
# ============================================

# Node Environment
NODE_ENV=development

# Port (for local development)
PORT=3000

# Frontend URL (for CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend URL (for API calls)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# WebSocket URL (for real-time sync)
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ============================================
# FEATURE FLAGS
# ============================================

# Media Sources
ENABLE_YOUTUBE_SYNC=true
ENABLE_SPOTIFY_SEARCH=true
ENABLE_SPOTIFY_PREVIEW=true
ENABLE_FILE_UPLOADS=true
ENABLE_GIF_SEARCH=true
ENABLE_VIDEO_CALL=true

# Rate Limiting (conservative for free tiers)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# DEPLOYMENT (Railway + Vercel)
# ============================================

# Railway App URL (backend hosting - $1 credit/month, no sleep)
# https://railway.app/
RAILWAY_PROJECT_ID=your_railway_project_id
RAILWAY_ENVIRONMENT_ID=your_railway_environment_id

# Vercel Project ID (frontend hosting)
# https://vercel.com/
VERCEL_PROJECT_ID=your_vercel_project_id

# GitHub Repository (for auto-deploy)
GITHUB_REPO=yourusername/cozzywood
